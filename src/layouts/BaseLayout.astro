---
import "../styles/global.css";

type Props = {
	title: string;
	description?: string;
};

const { title, description = "Portfolio pessoal" } = Astro.props as Props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
