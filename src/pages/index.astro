---
import "./index.styles.css";
import HomePage from "../components/HomePage.astro";
import { myData, projects } from "@Data";

const featuredProjects = projects.filter((project) => project.isSpotlight);

const baseUrl = Astro.site ?? new URL("https://samuel.dev");
const pageUrl = new URL("/", baseUrl).toString();

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Person",
		name: myData.name,
		jobTitle: "Desenvolvedor Fullstack",
		url: pageUrl,
		email: `mailto:${myData.contact.email}`,
		telephone: myData.contact.phone,
		sameAs: ["https://github.com/Samuel-lab-prog", "https://wa.me/5551991669896"],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "samuel.dev",
		url: pageUrl,
		inLanguage: "pt-BR",
	},
	{
		"@context": "https://schema.org",
		"@type": "ItemList",
		name: "Projetos de portfólio",
		itemListElement: featuredProjects.map((project, index) => ({
			"@type": "ListItem",
			position: index + 1,
			name: project.name,
			url: project.visitUrl,
			description: project.description,
		})),
	},
];
---

<HomePage
	lang="pt"
	ptPath="/"
	enPath="/en"
	canonicalPath="/"
	alternateHref="/en"
	brand="samuel.dev"
	brandHref="/"
	data={myData}
	projects={featuredProjects}
	structuredData={structuredData}
	resumeHref="/resume"
	copy={{
		pageTitle: "samuel.dev",
		pageDescription:
			"Portfólio de desenvolvedor full stack com foco em React, TypeScript, Node.js, DDD, CQRS e projetos reais com testes e deploy.",
		pageKeywords: ["desenvolvedor fullstack", "portfolio desenvolvedor", "react", "typescript", "astro", "ddd", "cqrs"],
		htmlLang: "pt-BR",
		alternateHreflang: "en",
		ogLocale: "pt_BR",
		navbarMenuLabel: "Abrir menu",
		navbarLanguageLabel: "Idioma",
		navbarLanguagePtLabel: "Português",
		navbarLanguageEnLabel: "English",
		hero: {
			projectsLabel: "Ver projetos",
			experienceLabel: "Experiência",
			resumeLabel: "Currículo",
		},
		projects: {
			title: "Projetos com impacto",
			card: {
				availableLabel: "Disponível",
				unavailableLabel: "Indisponível",
				availableMessage: "Disponível: projeto hospedado e com infraestrutura ativa.",
				unavailableMessage: "Indisponível no momento: hospedagem e banco desativados para reduzir custos.",
				visitProjectLabel: "Visitar projeto",
				viewGithubLabel: "Ver no GitHub",
				prevImageLabel: "Imagem anterior",
				nextImageLabel: "Próxima imagem",
				closeLabel: "Fechar",
				expandedImageLabel: "Imagem ampliada do projeto",
				availableProjectLabel: "Projeto disponível",
				unavailableProjectLabel: "Projeto indisponível",
			},
		},
		experienceTitle: "Experiência",
		skillsTitle: "Habilidades",
		technologiesTitle: "Tecnologias que uso diariamente",
		workflowTitle: "Como eu desenvolvo software",
		languagesTitle: "Idiomas",
		contact: {
			title: "Contato",
			intro: myData.contact.intro,
			emailLabel: "Email",
			phoneLabel: "Telefone",
		},
		footer: {
			title: "Samuel Gomes Monni",
			subtitle: "Desenvolvedor Fullstack • Arquitetura • Qualidade de Software",
			yearSuffix: "Todos os direitos reservados.",
			emailLabel: "Enviar e-mail",
			phoneLabel: "Abrir WhatsApp",
			githubLabel: "Abrir GitHub",
			projectsLabel: "Ir para projetos",
		},
		script: {
			closeLabel: "Fechar",
			prevImageLabel: "Imagem anterior",
			nextImageLabel: "Próxima imagem",
			imageAltLabel: "Imagem ampliada do projeto",
		},
	}}
/>
