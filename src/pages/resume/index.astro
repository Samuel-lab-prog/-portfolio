---
import "./styles.css";
import ResumePage from "../../components/ResumePage.astro";
import { resumeData } from "@Data";

const baseUrl = Astro.site ?? new URL("https://samuel.dev");
const pageUrl = new URL("/resume", baseUrl).toString();

const uiCopy = {
	pageTitle: "Currículo | Samuel Gomes Monni",
	pageDescription: "Currículo em PDF gerado a partir dos dados do portfólio.",
	pageKeywords: ["currículo", "pdf", "desenvolvedor fullstack", "samuel gomes monni", "lattes"],
	toolbarTitle: "Currículo em PDF",
	toolbarDescription: "Versão enxuta e legível para impressão, construída a partir dos dados do currículo.",
	printButton: "Gerar PDF",
	backLink: "Voltar ao portfólio",
	languageLabel: "Idioma",
	ptLabel: "Português",
	enLabel: "Inglês",
};

const documentCopy = {
	resumeLabel: "Currículo em português",
	contactsLabel: "Contatos",
	summaryTitle: "Resumo",
	skillsTitle: "Competências-chave",
	experienceTitle: "Experiência",
	projectsTitle: "Projetos relevantes",
	technologiesTitle: "Tecnologias",
	languagesTitle: "Idiomas",
};

const structuredData = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: resumeData.name,
	jobTitle: resumeData.title,
	inLanguage: "pt",
	url: pageUrl,
	email: "mailto:samuel.gomes.5762@gmail.com",
	sameAs: [
		"https://github.com/Samuel-lab-prog",
		"http://lattes.cnpq.br/0187401279570368",
		"https://wa.me/5551991669896",
	],
};
---

<ResumePage
	lang="pt"
	ptPath="/resume"
	enPath="/resume-en"
	canonicalPath="/resume"
	alternateHref="/resume-en"
	htmlLang="pt-BR"
	alternateHreflang="en"
	ogLocale="pt_BR"
	structuredData={structuredData}
	data={resumeData}
	documentCopy={documentCopy}
	uiCopy={uiCopy}
/>
