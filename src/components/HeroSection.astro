---
import Icon from "./Icon.astro";
type Props = {
	eyebrow: string;
	name: string;
	description: string;
};

const { eyebrow, name, description } = Astro.props as Props;
---

<section class="hero">
	<p class="eyebrow">{eyebrow}</p>
	<h1>{name}</h1>
	<p>{description}</p>
	<div class="actions">
		<a href="#projetos"><span aria-hidden="true"><Icon name="rocket" /></span> Ver projetos</a>
		<a href="#experiencia" class="ghost"><span aria-hidden="true"><Icon name="briefcase" /></span> Experiência</a>
	</div>
</section>
