---
import Icon from "./Icon.astro";
type Props = {
	eyebrow: string;
	name: string;
	description: string;
	proofs: string[];
	actions: {
		projectsLabel: string;
		experienceLabel: string;
		resumeLabel: string;
		resumeHref: string;
	};
};

const { eyebrow, name, description, proofs, actions } = Astro.props as Props;
---

<section class="hero">
	<p class="eyebrow">{eyebrow}</p>
	<h1>{name}</h1>
	<p>{description}</p>
	<ul class="hero-proofs" aria-label="Destaques profissionais">
		{proofs.map((proof) => <li>{proof}</li>)}
	</ul>
	<div class="actions">
		<a href="#projetos"><span aria-hidden="true"><Icon name="rocket" /></span> {actions.projectsLabel}</a>
		<a href="#experiencia" class="ghost"><span aria-hidden="true"><Icon name="briefcase" /></span> {actions.experienceLabel}</a>
		<a href={actions.resumeHref} class="ghost"><span aria-hidden="true"><Icon name="download" /></span> {actions.resumeLabel}</a>
	</div>
</section>
