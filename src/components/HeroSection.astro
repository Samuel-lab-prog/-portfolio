---
import Icon from "./Icon.astro";

type Props = {
	eyebrow: string;
	name: string;
	description: string;
	actions: {
		projectsLabel: string;
		experienceLabel: string;
		resumeLabel: string;
		resumeHref: string;
	};
};

const { eyebrow, name, description, actions } = Astro.props as Props;
---

<section class="space-y-6">
	<p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">{eyebrow}</p>
	<h1 class="max-w-4xl text-4xl font-black leading-[1.02] tracking-tight text-slate-50 sm:text-5xl lg:text-7xl">{name}</h1>
	<p class="max-w-3xl text-base leading-7 text-slate-300 sm:text-lg">{description}</p>
	<div class="flex flex-wrap gap-3 pt-2">
		<a
			href="#projetos"
			class="inline-flex items-center gap-2 rounded-xl border border-cyan-300/20 bg-cyan-300 px-4 py-3 text-sm font-bold text-slate-950 no-underline transition hover:-translate-y-0.5 hover:brightness-105"
		>
			<span aria-hidden="true"><Icon name="rocket" class="h-4 w-4" /></span> {actions.projectsLabel}
		</a>
		<a
			href="#experiencia"
			class="inline-flex items-center gap-2 rounded-xl border border-slate-600 bg-transparent px-4 py-3 text-sm font-bold text-slate-200 no-underline transition hover:-translate-y-0.5 hover:border-cyan-300/40 hover:text-cyan-100"
		>
			<span aria-hidden="true"><Icon name="briefcase" class="h-4 w-4" /></span> {actions.experienceLabel}
		</a>
		<a
			href={actions.resumeHref}
			class="inline-flex items-center gap-2 rounded-xl border border-slate-600 bg-transparent px-4 py-3 text-sm font-bold text-slate-200 no-underline transition hover:-translate-y-0.5 hover:border-cyan-300/40 hover:text-cyan-100"
		>
			<span aria-hidden="true"><Icon name="download" class="h-4 w-4" /></span> {actions.resumeLabel}
		</a>
	</div>
</section>
