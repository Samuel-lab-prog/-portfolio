---
import type { PortfolioProject } from "../data/projects";
import Icon from "./Icon.astro";

type Props = {
	project: PortfolioProject;
};

const { project } = Astro.props as Props;
---

<article data-categories={project.categories.join(",")}>
	<h3>{project.name}</h3>
	<p>{project.description}</p>
	<div class="keyword-list">
		{project.keywords.map((keyword) => <span class="keyword-pill">{keyword}</span>)}
	</div>
	<div class="project-links">
		<a href={project.visitUrl} target="_blank" rel="noreferrer"><Icon name="external" /> Visitar projeto</a>
		<a href={project.githubUrl} target="_blank" rel="noreferrer"><Icon name="github" /> Ver no GitHub</a>
	</div>
	<div id={`gallery-${project.id}`} class="carousel" data-index="0">
		<button class="carousel-control prev" type="button" aria-label="Imagem anterior">
			&lt;
		</button>
		<div class="carousel-stage">
			{project.prints.map((print, index) => (
				<img
					src={print.src}
					alt={print.alt}
					class={`carousel-image ${index === 0 ? "is-active" : ""}`}
					loading="lazy"
				/>
			))}
		</div>
		<button class="carousel-control next" type="button" aria-label="Próxima imagem">
			&gt;
		</button>
	</div>
</article>
