---
import Icon from "./Icon.astro";
type Props = {
	copy: {
		title: string;
		subtitle: string;
		yearSuffix: string;
		emailLabel: string;
		phoneLabel: string;
		githubLabel: string;
		projectsLabel: string;
	};
};

const { copy } = Astro.props as Props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer-inner">
		<p class="footer-title">{copy.title}</p>
		<p class="footer-subtitle">{copy.subtitle}</p>
		<div class="site-footer-icons">
			<a href="mailto:samuel.gomes.5762@gmail.com" aria-label={copy.emailLabel}>
				<Icon name="mail" />
			</a>
			<a href="https://wa.me/5551991669896" target="_blank" rel="noreferrer" aria-label={copy.phoneLabel}>
				<Icon name="phone" />
			</a>
			<a href="https://github.com/Samuel-lab-prog" target="_blank" rel="noreferrer" aria-label={copy.githubLabel}>
				<Icon name="github" />
			</a>
			<a href="#projetos" aria-label={copy.projectsLabel}>
				<Icon name="beaker" />
			</a>
		</div>
		<p class="footer-copy">© {year} {copy.yearSuffix}</p>
	</div>
</footer>
