---
import Icon from "./Icon.astro";

type NavItem = { label: string; href: string };

type Props = {
	brand: string;
	brandHref: string;
	items: NavItem[];
	menuLabel: string;
	language?: {
		current: "pt" | "en";
		ptHref: string;
		enHref: string;
		ptLabel: string;
		enLabel: string;
		ariaLabel: string;
	};
};

const { brand, brandHref, items, menuLabel, language } = Astro.props as Props;
---

<nav class="sticky top-0 z-20 border-b border-slate-700/70 bg-slate-950/80 backdrop-blur-xl" data-navbar data-open="false">
	<div class="relative mx-auto flex min-h-[88px] max-w-[1040px] items-center gap-4 px-4 py-4 sm:px-5">
		<a class="inline-flex items-center gap-2 text-lg font-extrabold tracking-wide text-slate-50 no-underline" href={brandHref}>
			<Icon name="sparkles" class="h-5 w-5 text-cyan-300" /> {brand}
		</a>
		<div class="ml-auto flex items-center gap-3">
			{
				language && (
					<div class="inline-flex items-center gap-1 rounded-full border border-slate-700 bg-slate-900 p-1" aria-label={language.ariaLabel}>
						<a
							class:list={{
								"rounded-full px-3 py-2 text-sm font-bold leading-none text-slate-400 no-underline transition hover:text-cyan-200": true,
								"bg-cyan-300 text-slate-950": language.current === "pt",
							}}
							href={language.ptHref}
							aria-current={language.current === "pt" ? "page" : undefined}
						>
							{language.ptLabel}
						</a>
						<a
							class:list={{
								"rounded-full px-3 py-2 text-sm font-bold leading-none text-slate-400 no-underline transition hover:text-cyan-200": true,
								"bg-cyan-300 text-slate-950": language.current === "en",
							}}
							href={language.enHref}
							aria-current={language.current === "en" ? "page" : undefined}
						>
							{language.enLabel}
						</a>
					</div>
				)
			}
			<button
				class="inline-flex h-10 w-10 flex-col items-center justify-center gap-1 rounded-xl border border-slate-700 bg-slate-900 text-slate-100 md:hidden"
				type="button"
				aria-label={menuLabel}
				aria-expanded="false"
				data-navbar-toggle
			>
				<span class="h-0.5 w-4 rounded-full bg-current"></span>
				<span class="h-0.5 w-4 rounded-full bg-current"></span>
				<span class="h-0.5 w-4 rounded-full bg-current"></span>
			</button>
		</div>
		<div
			class="absolute inset-x-4 top-[calc(100%+0.5rem)] z-30 flex max-h-0 flex-col gap-3 overflow-hidden rounded-2xl border border-slate-700 bg-slate-900 p-3 opacity-0 pointer-events-none transition-all md:static md:ml-0 md:flex md:max-h-none md:flex-row md:items-center md:gap-3 md:border-0 md:bg-transparent md:p-0 md:opacity-100 md:pointer-events-auto data-[open=true]:max-h-80 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto"
			data-navbar-links
		>
			{
				items.map((item) => (
					<a class="rounded-lg px-2 py-2 text-sm font-semibold text-slate-300 no-underline transition hover:text-cyan-200 md:px-0" href={item.href}>
						{item.label}
					</a>
				))
			}
		</div>
	</div>
</nav>
